# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DB_NAME=ims
DB_USER=ims_user
DB_PASSWORD=changeme_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://ims_user:changeme_db@db:5432/ims
DATABASE_URL_SYNC=postgresql://ims_user:changeme_db@db:5432/ims

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@redis:6379/0

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
SEED_ON_STARTUP=true
CORS_ORIGINS=http://localhost,http://localhost:80
ENVIRONMENT=development
