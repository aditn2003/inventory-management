# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DB_NAME=ims
DB_USER=ims_user
DB_PASSWORD=db_password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://ims_user:db_password@db:5432/ims
DATABASE_URL_SYNC=postgresql://ims_user:db_password@db:5432/ims

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
SEED_ON_STARTUP=true
CORS_ORIGINS=http://localhost,http://localhost:80
ENVIRONMENT=development
# Base URL of the web app (invite emails link here), no trailing slash
PUBLIC_APP_URL=http://localhost

# ─────────────────────────────────────────
# Resend — invitation emails (https://resend.com) — required for “Invite user”
# ─────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
# Must be a verified sender in Resend (default works for testing on Resend free tier)
RESEND_FROM_EMAIL=IMS <onboarding@resend.dev>
INVITE_EXPIRE_HOURS=168

# ─────────────────────────────────────────
# Google OAuth 2.0 — Sign in with Google (optional)
# Create OAuth client: Google Cloud Console → APIs & Services → Credentials
# Application type: Web. Authorized redirect URI must match exactly, e.g.:
#   http://localhost/api/v1/auth/google/callback
# ─────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Leave empty to use PUBLIC_APP_URL + /api/v1/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
